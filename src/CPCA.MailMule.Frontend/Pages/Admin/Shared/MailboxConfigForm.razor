@using CPCA.MailMule.Dtos
@using CPCA.MailMule.Frontend.Services

<MudForm @ref="form" @bind-IsValid="@isFormValid">
    <MudStack Spacing="2">
        <MudTextField @bind-Value="formData.DisplayName" Label="Display Name" Required="true" 
            Variant="Variant.Outlined" HelperText="Unique identifier for this mailbox" />
        
        <MudTextField @bind-Value="formData.ImapHost" Label="IMAP Host" Required="true" 
            Variant="Variant.Outlined" HelperText="e.g., imap.gmail.com" />
        
        <MudNumericField @bind-Value="formData.ImapPort" Label="Port" 
            Variant="Variant.Outlined" Min="1" Max="65535" HelperText="Usually 993 for IMAP" />
        
        <MudSelect @bind-Value="formData.Security" Label="Security" T="String" AnchorOrigin="Origin.BottomCenter">
            <MudSelectItem Value="@("SSL")">SSL/TLS</MudSelectItem>
            <MudSelectItem Value="@("STARTTLS")">STARTTLS</MudSelectItem>
            <MudSelectItem Value="@("Auto")">Auto-detect</MudSelectItem>
        </MudSelect>
        
        <MudTextField @bind-Value="formData.Username" Label="Username" Required="true"
            Variant="Variant.Outlined" HelperText="Email address or username" />
        
        <MudTextField @bind-Value="formData.Password" Label="Password" InputType="InputType.Password"
            Variant="Variant.Outlined" 
            HelperText="@(IsEditing ? "Leave blank to keep existing password" : "Required for new mailbox")" />
        
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@DiscoverFolders" Disabled="@IsDiscovering">
            @if (IsDiscovering)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Discover Folders
        </MudButton>

        @if (DiscoveredFolders.Count > 0)
        {
            <MudAlert Severity="Severity.Success" Dense="true">
                Connected! Found @DiscoveredFolders.Count folder(s). Use the folders section below to configure.
            </MudAlert>
        }

        @if (!String.IsNullOrEmpty(DiscoveryMessage) && DiscoveredFolders.Count == 0)
        {
            <MudAlert Severity="Severity.Error" Dense="true">
                @DiscoveryMessage
            </MudAlert>
        }

        <MudExpansionPanels>
            <MudExpansionPanel Text="Folders" is-initially-expanded="@(DiscoveredFolders.Count > 0)">
                <MudStack Spacing="2">
                    @if (DiscoveredFolders.Count > 0)
                    {
                        @if (IsIncoming)
                        {
                            <MudSelect T="String" @bind-Value="formData.InboxFolderPath" Label="Inbox Folder *" Required="true"
                                Variant="Variant.Outlined">
                                @foreach (var folder in DiscoveredFolders)
                                {
                                    <MudSelectItem T="String" Value="@folder">@folder</MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect T="String" @bind-Value="formData.JunkFolderPath" Label="Junk Folder *" Required="true"
                                Variant="Variant.Outlined">
                                <MudSelectItem T="String" Value="@("")"><em>-- Select --</em></MudSelectItem>
                                @foreach (var folder in DiscoveredFolders)
                                {
                                    <MudSelectItem T="String" Value="@folder">@folder</MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect T="String" @bind-Value="formData.ArchiveFolderPath" Label="Archive Folder *" Required="@(!formData.DeleteMessage)"
                                Variant="Variant.Outlined"
                                HelperText="@(formData.DeleteMessage ? "Not required when deleting messages" : "Required when archiving messages")">
                                <MudSelectItem T="String" Value="@("")"><em>-- Select --</em></MudSelectItem>
                                @foreach (var folder in DiscoveredFolders)
                                {
                                    <MudSelectItem T="String" Value="@folder">@folder</MudSelectItem>
                                }
                            </MudSelect>
                        }
                        else
                        {
                            <MudSelect T="String" @bind-Value="formData.OutboxFolderPath" Label="Destination Folder *" Required="true"
                                Variant="Variant.Outlined"
                                HelperText="This is where routed messages will be delivered">
                                <MudSelectItem T="String" Value="@("")"><em>-- Select --</em></MudSelectItem>
                                @foreach (var folder in DiscoveredFolders)
                                {
                                    <MudSelectItem T="String" Value="@folder">@folder</MudSelectItem>
                                }
                            </MudSelect>
                        }
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">
                            Click "Discover Folders" to retrieve available folders from the IMAP server.
                        </MudAlert>
                    }
                </MudStack>
            </MudExpansionPanel>

            <MudExpansionPanel Text="Advanced Settings">
                <MudStack Spacing="2">
                    <MudNumericField @bind-Value="formData.PollIntervalSeconds" Label="Polling Interval (seconds)" 
                        Variant="Variant.Outlined" Min="10" Max="3600" HelperText="How often to check for new messages" />

                    @if (IsIncoming)
                    {
                        <MudCheckBox T="Boolean" @bind-Value="formData.DeleteMessage" Label="Delete message after routing (instead of archiving)" />
                    }
                    
                    <MudCheckBox T="Boolean" @bind-Value="formData.IsActive" Label="Active" />
                    
                    <MudNumericField @bind-Value="formData.SortOrder" Label="Sort Order" 
                        Variant="Variant.Outlined" HelperText="Display order in list" />
                </MudStack>
            </MudExpansionPanel>
        </MudExpansionPanels>

        @if (!String.IsNullOrEmpty(ValidationMessage))
        {
            <MudAlert Severity="Severity.Error">
                @ValidationMessage
            </MudAlert>
        }

        <MudStack Row="true" Class="mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                Disabled="@(!isFormValid || IsSaving)" OnClick="@(async () => await OnSubmit())" Class="flex-grow-1">
                @(IsSaving ? "Saving..." : (IsEditing ? "Update" : "Create"))
            </MudButton>
            <MudButton Variant="Variant.Text" OnClick="@OnCancel">Cancel</MudButton>
        </MudStack>
    </MudStack>
</MudForm>

@code {
    private MudForm? form;
    private bool isFormValid;
    private FormData formData = new();
    private List<String> DiscoveredFolders { get; set; } = new();
    private String? DiscoveryMessage;
    private String? ValidationMessage;
    private Boolean IsDiscovering;

    private bool IsIncoming => Request.MailboxType.Equals("Incoming", StringComparison.OrdinalIgnoreCase);

    private class FormData
    {
        public string DisplayName { get; set; } = "";
        public string ImapHost { get; set; } = "";
        public int ImapPort { get; set; } = 993;
        public string Security { get; set; } = "Auto";
        public string Username { get; set; } = "";
        public string? Password { get; set; }
        public string? InboxFolderPath { get; set; }
        public string? OutboxFolderPath { get; set; }
        public string? SentFolderPath { get; set; }
        public string? ArchiveFolderPath { get; set; }
        public string? JunkFolderPath { get; set; }
        public int PollIntervalSeconds { get; set; } = 300;
        public bool DeleteMessage { get; set; }
        public bool IsActive { get; set; } = true;
        public int SortOrder { get; set; }
    }

    [Parameter]
    public bool IsEditing { get; set; }

    [Parameter]
    public CreateMailboxConfigDto Request { get; set; } = new(
        DisplayName: "",
        ImapHost: "",
        ImapPort: 993,
        MailboxType: "Incoming",
        Security: "Auto",
        Username: "",
        Password: "",
        InboxFolderPath: null,
        OutboxFolderPath: null,
        SentFolderPath: null,
        ArchiveFolderPath: null,
        JunkFolderPath: null,
        PollIntervalSeconds: 300,
        DeleteMessage: false,
        IsActive: true,
        SortOrder: 0
    );

    [Parameter]
    public EventCallback<CreateMailboxConfigDto> OnSubmitCallback { get; set; }

    [Parameter]
    public EventCallback OnCancelCallback { get; set; }

    public bool IsSaving { get; set; }

    [Inject]
    public MailboxConfigApiClient? ApiClient { get; set; }

    [Inject]
    public ISnackbar? Snackbar { get; set; }

    protected override void OnParametersSet()
    {
        formData.DisplayName = Request.DisplayName ?? "";
        formData.ImapHost = Request.ImapHost ?? "";
        formData.ImapPort = Request.ImapPort;
        formData.Security = Request.Security ?? "Auto";
        formData.Username = Request.Username ?? "";
        formData.Password = Request.Password;
        formData.InboxFolderPath = Request.InboxFolderPath;
        formData.OutboxFolderPath = Request.OutboxFolderPath;
        formData.SentFolderPath = Request.SentFolderPath;
        formData.ArchiveFolderPath = Request.ArchiveFolderPath;
        formData.JunkFolderPath = Request.JunkFolderPath;
        formData.PollIntervalSeconds = Request.PollIntervalSeconds;
        formData.DeleteMessage = Request.DeleteMessage;
        formData.IsActive = Request.IsActive;
        formData.SortOrder = Request.SortOrder;
    }

    private async Task DiscoverFolders()
    {
        if (ApiClient == null) return;

        ValidationMessage = null;
        IsDiscovering = true;
        DiscoveredFolders.Clear();
        DiscoveryMessage = null;

        try
        {
            var testRequest = new MailboxConnectionTestRequest(
                ImapHost: formData.ImapHost,
                ImapPort: formData.ImapPort,
                Security: formData.Security,
                Username: formData.Username,
                Password: formData.Password ?? ""
            );

            var result = await ApiClient.TestConnectionAsync(testRequest, Request.MailboxType);
            
            if (result == null)
            {
                DiscoveryMessage = "Connection test failed. Please check your credentials.";
            }
            else if (!result.Success)
            {
                DiscoveryMessage = result.Message ?? "Connection failed.";
                DiscoveredFolders.Clear();
            }
            else
            {
                DiscoveredFolders = result.FolderList?.ToList() ?? new List<String>();
                
                if (DiscoveredFolders.Count == 0)
                {
                    DiscoveryMessage = "Connected but no folders found.";
                }
                else
                {
                    DiscoveryMessage = null;
                    if (String.IsNullOrEmpty(formData.InboxFolderPath) && IsIncoming && DiscoveredFolders.Any(f => f.Equals("INBOX", StringComparison.OrdinalIgnoreCase)))
                    {
                        formData.InboxFolderPath = "INBOX";
                    }
                }
            }
        }
        finally
        {
            IsDiscovering = false;
        }
    }

    private bool ValidateForm()
    {
        ValidationMessage = null;

        if (IsIncoming)
        {
            if (DiscoveredFolders.Count == 0)
            {
                ValidationMessage = "Please discover folders first by clicking 'Discover Folders'.";
                return false;
            }

            if (String.IsNullOrWhiteSpace(formData.InboxFolderPath))
            {
                ValidationMessage = "Inbox Folder is required.";
                return false;
            }

            if (String.IsNullOrWhiteSpace(formData.JunkFolderPath))
            {
                ValidationMessage = "Junk Folder is required.";
                return false;
            }

            if (!formData.DeleteMessage && String.IsNullOrWhiteSpace(formData.ArchiveFolderPath))
            {
                ValidationMessage = "Archive Folder is required when not deleting messages.";
                return false;
            }
        }
        else
        {
            if (DiscoveredFolders.Count == 0)
            {
                ValidationMessage = "Please discover folders first by clicking 'Discover Folders'.";
                return false;
            }

            if (String.IsNullOrWhiteSpace(formData.OutboxFolderPath))
            {
                ValidationMessage = "Destination Folder is required.";
                return false;
            }
        }

        return true;
    }

    private async Task OnSubmit()
    {
        if (form != null)
        {
            await form.ValidateAsync();
        }

        if (!isFormValid) return;
        
        if (!ValidateForm()) return;

        IsSaving = true;
        var updatedRequest = new CreateMailboxConfigDto(
            DisplayName: formData.DisplayName,
            ImapHost: formData.ImapHost,
            ImapPort: formData.ImapPort,
            MailboxType: Request.MailboxType,
            Security: formData.Security,
            Username: formData.Username,
            Password: formData.Password ?? "",
            InboxFolderPath: formData.InboxFolderPath,
            OutboxFolderPath: formData.OutboxFolderPath,
            SentFolderPath: formData.SentFolderPath,
            ArchiveFolderPath: String.IsNullOrWhiteSpace(formData.ArchiveFolderPath) ? null : formData.ArchiveFolderPath,
            JunkFolderPath: String.IsNullOrWhiteSpace(formData.JunkFolderPath) ? null : formData.JunkFolderPath,
            PollIntervalSeconds: formData.PollIntervalSeconds,
            DeleteMessage: formData.DeleteMessage,
            IsActive: formData.IsActive,
            SortOrder: formData.SortOrder
        );
        await OnSubmitCallback.InvokeAsync(updatedRequest);
        IsSaving = false;
    }

    private async Task OnCancel()
    {
        await OnCancelCallback.InvokeAsync();
    }    
}
