@using MudBlazor
@using Microsoft.AspNetCore.Authorization
@page "/admin/app-settings"
@using CPCA.MailMule.Dtos
@using CPCA.MailMule.Frontend.Services
@attribute [Authorize(Roles = "Admin")]
@inject IApplicationSettingsApiClient AppSettingsApiClient
@inject ISnackbar Snackbar

<PageTitle>Application Settings</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.h4">Application Settings</MudText>

    @if (loading)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else if (appSettings != null)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            Changes to application settings affect all users.
        </MudAlert>

        <MudPaper Class="pa-4" MaxWidth="600px">
            <MudStack Spacing="3">
                <MudNumericField @bind-Value="appSettings.InactivityTimeoutMinutes"
                    Label="Inactivity Timeout (minutes)"
                    HelperText="Auto-release king of the hill after inactivity (5–120)"
                    Min="5" Max="120"
                    Variant="Variant.Outlined" />
            </MudStack>
        </MudPaper>

        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                OnClick="@SaveAsync" Disabled="@saving">
                @if (saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Save
            </MudButton>
        </MudStack>
    }
    else
    {
        <MudAlert Severity="Severity.Error">Failed to load settings.</MudAlert>
    }
</MudStack>

@code {
    private AppSettingsModel? appSettings;
    private Boolean loading = true;
    private Boolean saving;

    protected override async Task OnInitializedAsync()
    {
        await LoadSettingsAsync();
    }

    private async Task LoadSettingsAsync()
    {
        loading = true;
        try
        {
            var appDto = await AppSettingsApiClient.GetAsync();

            if (appDto != null)
            {
                appSettings = new AppSettingsModel
                {
                    InactivityTimeoutMinutes = appDto.InactivityTimeoutMinutes
                };
            }
        }
        finally
        {
            loading = false;
        }
    }

    private async Task SaveAsync()
    {
        if (appSettings == null) return;

        saving = true;
        try
        {
            var appDto = new ApplicationSettingsDto(appSettings.InactivityTimeoutMinutes);

            var success = await AppSettingsApiClient.UpdateAsync(appDto);

            if (success)
            {
                Snackbar.Add("Application settings saved.", Severity.Success);
            }
            else
            {
                Snackbar.Add("Failed to save application settings.", Severity.Error);
            }
        }
        finally
        {
            saving = false;
        }
    }

    private sealed class AppSettingsModel
    {
        public Int32 InactivityTimeoutMinutes { get; set; }
    }
}
