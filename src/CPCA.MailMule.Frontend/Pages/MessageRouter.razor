@page "/message/router"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@attribute [Authorize]
@implements IDisposable

<PageTitle>Message Routing</PageTitle>

<MudStack Spacing="2">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Message Routing</MudText>
        <MudButton Variant="Variant.Outlined" OnClick="LoadAsync" Disabled="@isLoading">Refresh</MudButton>
    </MudStack>

    @if (!String.IsNullOrWhiteSpace(statusMessage))
    {
        <MudAlert Severity="@statusSeverity">@statusMessage</MudAlert>
    }

    <MudGrid>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-3">
                <MudText Typo="Typo.h6" Class="mb-2">Incoming</MudText>
                @if (PostOffice.Inbox.Count == 0)
                {
                    <MudText Typo="Typo.body2">No messages available.</MudText>
                }
                else
                {
                    <MudList T="MessageHeaderDto">
                        @foreach (var header in PostOffice.Inbox)
                        {
                            <MudListItem T="MessageHeaderDto" Value="header" OnClick="@(() => SelectMessageAsync(header))" Class="mb-1">
                                <MudText Typo="Typo.subtitle2">@header.Subject</MudText>
                                <MudText Typo="Typo.caption">@FormatFrom(header.From)</MudText>
                                <MudText Typo="Typo.caption">@header.DateReceived.LocalDateTime</MudText>
                            </MudListItem>
                        }
                    </MudList>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="5">
            <MudPaper Class="pa-3">
                <MudText Typo="Typo.h6" Class="mb-2">Message</MudText>
                @if (selectedHeader == null)
                {
                    <MudText Typo="Typo.body2">Select a message to view content.</MudText>
                }
                else if (isLoadingMessage)
                {
                    <MudProgressCircular Indeterminate="true" />
                }
                else
                {
                    <MudText Typo="Typo.subtitle2" Class="mb-2">@selectedHeader.Subject</MudText>
                    <MudText Typo="Typo.caption" Class="mb-2">@FormatFrom(selectedHeader.From)</MudText>

                    @if (!String.IsNullOrWhiteSpace(sanitizedHtmlBody))
                    {
                        <MudPaper Class="pa-2" Outlined="true" Style="max-height: 460px; overflow: auto;">
                            @htmlPreview
                        </MudPaper>
                    }
                    else
                    {
                        <MudPaper Class="pa-2" Outlined="true" Style="max-height: 460px; overflow: auto; white-space: pre-wrap; font-family: Consolas, monospace;">
                            @(plainTextBody ?? "(Unable to load message body)")
                        </MudPaper>
                    }
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="3">
            <MudPaper Class="pa-3">
                <MudText Typo="Typo.h6" Class="mb-2">Actions</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Warning" Disabled="@(selectedHeader == null)" OnClick="QueueJunkAsync" FullWidth="true" Class="mb-2">
                    Mark as Junk
                </MudButton>

                <MudDivider Class="my-2" />
                <MudText Typo="Typo.subtitle2" Class="mb-1">Route To Mailbox</MudText>

                @if (outgoingMailboxes.Count == 0)
                {
                    <MudText Typo="Typo.caption">No outgoing mailboxes configured.</MudText>
                }
                else
                {
                    @foreach (var mailbox in outgoingMailboxes)
                    {
                        <MudButton Variant="Variant.Outlined" Disabled="@(selectedHeader == null)" OnClick="@(() => QueueRouteToMailboxAsync(mailbox))" FullWidth="true" Class="mb-1">
                            @mailbox.DisplayName
                        </MudButton>
                    }
                }

                <MudDivider Class="my-2" />
                <MudText Typo="Typo.subtitle2" Class="mb-1">Outbox Queue</MudText>

                @if (PostOffice.Outbox.Count == 0)
                {
                    <MudText Typo="Typo.caption">No pending routes.</MudText>
                }
                else
                {
                    @foreach (var pending in PostOffice.Outbox)
                    {
                        <MudPaper Class="pa-2 mb-2" Outlined="true">
                            <MudText Typo="Typo.caption">@pending.MessageHeader.Subject</MudText>
                            <MudText Typo="Typo.caption">
                                @(pending.Action == PostOffice.PendingAction.Junk ? "Junk" : $"Route: {GetMailboxDisplayName(pending.Destination)}")
                            </MudText>
                            <MudText Typo="Typo.caption">Undo: @pending.RemainingSeconds s</MudText>
                            <MudStack Row="true" Spacing="1" Class="mt-1">
                                <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@(() => CancelPending(pending.MessageHeader.MessageId))">Cancel</MudButton>
                                <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => ExecuteNowAsync(pending.MessageHeader.MessageId))">Execute</MudButton>
                            </MudStack>
                        </MudPaper>
                    }
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    [Inject]
    public MessageApiClient MessageApiClient { get; set; } = default!;

    [Inject]
    public MailboxConfigApiClient MailboxConfigApiClient { get; set; } = default!;

    [Inject]
    public PostOffice PostOffice { get; set; } = default!;

    private readonly List<MailboxConfigDto> outgoingMailboxes = [];
    private readonly CancellationTokenSource timerCts = new();
    private readonly SemaphoreSlim inboxSyncLock = new(1, 1);
    private readonly Ganss.Xss.HtmlSanitizer htmlSanitizer = new();

    private MessageHeaderDto? selectedHeader;
    private String? plainTextBody;
    private String? sanitizedHtmlBody;
    private MarkupString htmlPreview;

    private Boolean isLoading;
    private Boolean isLoadingMessage;
    private Int32 inboxPollSeconds = 30;

    private String? statusMessage;
    private Severity statusSeverity = Severity.Info;
    protected override async Task OnInitializedAsync()
    {
        PostOffice.Changed += HandlePostOfficeChanged;
        PostOffice.UndoWindowSeconds = 15;
        await LoadAsync();
        _ = Task.Run(() => RunPendingQueueAsync(timerCts.Token));
        _ = Task.Run(() => RunInboxSyncAsync(timerCts.Token));
    }

    private async Task LoadAsync()
    {
        await inboxSyncLock.WaitAsync(CancellationToken.None);
        try
        {
            isLoading = true;
            statusMessage = null;

            var loadedHeaders = await MessageApiClient.GetHeadersAsync();
            var loadedOutgoing = await MailboxConfigApiClient.GetMailboxesByTypeAsync("Outgoing") ?? [];
            var loadedIncoming = await MailboxConfigApiClient.GetMailboxesByTypeAsync("Incoming") ?? [];

            inboxPollSeconds = ResolveInboxPollIntervalSeconds(loadedIncoming);

            var syncedHeaders = loadedHeaders.Select(ToDto).ToArray();
            await PostOffice.SyncInboxAsync(syncedHeaders, CancellationToken.None);

            outgoingMailboxes.Clear();
            outgoingMailboxes.AddRange(loadedOutgoing.Where(x => x.IsActive));

            if (selectedHeader != null)
            {
                var stillExists = PostOffice.Inbox.FirstOrDefault(x => x.MessageId == selectedHeader.MessageId);
                if (stillExists == null)
                {
                    selectedHeader = null;
                    plainTextBody = null;
                    sanitizedHtmlBody = null;
                    htmlPreview = default;
                }
                else
                {
                    selectedHeader = stillExists;
                }
            }

            isLoading = false;
        }
        finally
        {
            inboxSyncLock.Release();
        }
    }

    private async Task SelectMessageAsync(MessageHeaderDto header)
    {
        selectedHeader = header;
        isLoadingMessage = true;
        plainTextBody = null;
        sanitizedHtmlBody = null;
        htmlPreview = default;

        var message = await MessageApiClient.GetMessageAsync(header.MessageId);
        plainTextBody = message?.TextBody;
        sanitizedHtmlBody = String.IsNullOrWhiteSpace(message?.HtmlBody)
            ? null
            : htmlSanitizer.Sanitize(message.HtmlBody);
        htmlPreview = new MarkupString(sanitizedHtmlBody ?? String.Empty);

        isLoadingMessage = false;
    }

    private Task QueueJunkAsync()
    {
        if (selectedHeader == null)
        {
            return Task.CompletedTask;
        }

        return PostOffice.QueueJunkAsync(selectedHeader, CancellationToken.None);
    }

    private Task QueueRouteToMailboxAsync(MailboxConfigDto destination)
    {
        if (selectedHeader == null)
        {
            return Task.CompletedTask;
        }

        return PostOffice.QueueDeliveryAsync(
            selectedHeader.MessageId,
            new MailboxId(ToGuidFromInt64(destination.Id)),
            CancellationToken.None);
    }

    private async Task CancelPending(MessageId messageId)
    {
        await PostOffice.CancelAsync(messageId, CancellationToken.None);

        statusSeverity = Severity.Info;
        statusMessage = "Queued route canceled and message returned to inbox.";
    }

    private async Task ExecuteNowAsync(MessageId messageId)
    {
        await PostOffice.ExecuteNowAsync(messageId, CancellationToken.None);
        await InvokeAsync(StateHasChanged);
    }

    private async Task RunPendingQueueAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        while (await timer.WaitForNextTickAsync(cancellationToken))
        {
            await InvokeAsync(async () =>
            {
                var due = PostOffice.GetDueEnvelopes(DateTimeOffset.UtcNow);

                foreach (var pending in due)
                {
                    await ExecutePendingAsync(pending);
                }

                StateHasChanged();
            });
        }
    }

    private async Task RunInboxSyncAsync(CancellationToken cancellationToken)
    {
        while (!cancellationToken.IsCancellationRequested)
        {
            try
            {
                await Task.Delay(TimeSpan.FromSeconds(inboxPollSeconds), cancellationToken);
                await RefreshInboxProjectionAsync(cancellationToken);
            }
            catch (OperationCanceledException)
            {
                break;
            }
            catch
            {
                statusSeverity = Severity.Error;
                statusMessage = "Automatic inbox sync failed. Retrying on the next cycle.";
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task RefreshInboxProjectionAsync(CancellationToken cancellationToken)
    {
        await inboxSyncLock.WaitAsync(cancellationToken);
        try
        {
            var loadedHeaders = await MessageApiClient.GetHeadersAsync();
            var syncedHeaders = loadedHeaders.Select(ToDto).ToArray();

            await PostOffice.SyncInboxAsync(syncedHeaders, cancellationToken);

            if (selectedHeader != null)
            {
                var stillExists = PostOffice.Inbox.FirstOrDefault(x => x.MessageId == selectedHeader.MessageId);
                if (stillExists == null)
                {
                    selectedHeader = null;
                    plainTextBody = null;
                    sanitizedHtmlBody = null;
                    htmlPreview = default;
                }
                else
                {
                    selectedHeader = stillExists;
                }
            }
        }
        finally
        {
            inboxSyncLock.Release();
        }
    }

    private async Task ExecutePendingAsync(PostOffice.PendingEnvelope pending)
    {
        Boolean success;

        if (pending.Action == PostOffice.PendingAction.Junk)
        {
            success = await MessageApiClient.RouteToJunkAsync(pending.MessageHeader.MessageId);
        }
        else
        {
            if (pending.Destination == null)
            {
                success = false;
            }
            else
            {
                success = await MessageApiClient.RouteToMailboxAsync(pending.MessageHeader.MessageId, pending.Destination.Value);
            }
        }

        if (success)
        {
            statusSeverity = Severity.Success;
            statusMessage = pending.Action == PostOffice.PendingAction.Junk
                ? "Message moved to junk."
                : $"Message routed successfully.";

            await PostOffice.MarkCompletedAsync(pending.MessageHeader.MessageId, CancellationToken.None);
        }
        else
        {
            statusSeverity = Severity.Error;
            statusMessage = pending.Action == PostOffice.PendingAction.Junk
                ? "Failed to move message to junk. Message returned to inbox."
                : "Failed to route message. Message returned to inbox.";

            await PostOffice.ReturnToInboxAsync(pending.MessageHeader.MessageId, CancellationToken.None);
        }
    }

    private void HandlePostOfficeChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private String GetMailboxDisplayName(MailboxId? mailboxId)
    {
        if (mailboxId == null)
        {
            return "Unknown mailbox";
        }

        var mailboxKey = ToInt64FromGuid(mailboxId.Value.Value);
        return outgoingMailboxes.FirstOrDefault(x => x.Id == mailboxKey)?.DisplayName ?? "Unknown mailbox";
    }

    private static MessageHeaderDto ToDto(MessageHeader header)
    {
        return new MessageHeaderDto
        {
            MessageId = header.Id,
            From = header.From,
            Subject = header.Subject,
            DateSent = header.Date,
            DateReceived = header.Date,
            To = []
        };
    }

    private static String FormatFrom(FullEmail from)
    {
        var name = String.Join(' ', new[] { from.Name.FirstName, from.Name.LastName }.Where(x => !String.IsNullOrWhiteSpace(x)));
        return String.IsNullOrWhiteSpace(name)
            ? from.Email.Value
            : $"{name} <{from.Email.Value}>";
    }

    private static Int32 ResolveInboxPollIntervalSeconds(IEnumerable<MailboxConfigDto> incomingMailboxes)
    {
        var configuredIntervals = incomingMailboxes
            .Where(x => x.IsActive)
            .Select(x => x.PollIntervalSeconds)
            .Where(x => x > 0)
            .ToList();

        if (configuredIntervals.Count == 0)
        {
            return 30;
        }

        return Math.Clamp(configuredIntervals.Min(), 5, 300);
    }

    private static Guid ToGuidFromInt64(Int64 value)
    {
        Span<byte> bytes = stackalloc byte[16];
        BitConverter.TryWriteBytes(bytes, value);
        return new Guid(bytes);
    }

    private static Int64 ToInt64FromGuid(Guid value)
    {
        var bytes = value.ToByteArray();
        return BitConverter.ToInt64(bytes, 0);
    }

    public void Dispose()
    {
        PostOffice.Changed -= HandlePostOfficeChanged;
        timerCts.Cancel();
        timerCts.Dispose();
    }
}
