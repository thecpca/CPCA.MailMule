@page "/message/router"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@implements IDisposable

<PageTitle>Message Routing</PageTitle>

<MudStack Spacing="2">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Message Routing</MudText>
        <MudButton Variant="Variant.Outlined" OnClick="LoadAsync" Disabled="@isLoading">Refresh</MudButton>
    </MudStack>

    @if (!String.IsNullOrWhiteSpace(statusMessage))
    {
        <MudAlert Severity="@statusSeverity">@statusMessage</MudAlert>
    }

    <MudGrid>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-3">
                <MudText Typo="Typo.h6" Class="mb-2">Incoming</MudText>
                @if (headers.Count == 0)
                {
                    <MudText Typo="Typo.body2">No messages available.</MudText>
                }
                else
                {
                    <MudList T="MessageHeader">
                        @foreach (var header in headers)
                        {
                            <MudListItem T="MessageHeader" Value="header" OnClick="@(() => SelectMessageAsync(header))" Class="mb-1">
                                <MudText Typo="Typo.subtitle2">@header.Subject</MudText>
                                <MudText Typo="Typo.caption">@FormatFrom(header.From)</MudText>
                                <MudText Typo="Typo.caption">@header.Date.LocalDateTime</MudText>
                            </MudListItem>
                        }
                    </MudList>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="5">
            <MudPaper Class="pa-3">
                <MudText Typo="Typo.h6" Class="mb-2">Message</MudText>
                @if (selectedHeader == null)
                {
                    <MudText Typo="Typo.body2">Select a message to view content.</MudText>
                }
                else if (isLoadingMessage)
                {
                    <MudProgressCircular Indeterminate="true" />
                }
                else
                {
                    <MudText Typo="Typo.subtitle2" Class="mb-2">@selectedHeader.Subject</MudText>
                    <MudText Typo="Typo.caption" Class="mb-2">@FormatFrom(selectedHeader.From)</MudText>
                    <MudPaper Class="pa-2" Outlined="true" Style="max-height: 460px; overflow: auto; white-space: pre-wrap; font-family: Consolas, monospace;">
                        @(rawMessage ?? "(Unable to load message body)")
                    </MudPaper>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="3">
            <MudPaper Class="pa-3">
                <MudText Typo="Typo.h6" Class="mb-2">Actions</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Warning" Disabled="@(selectedHeader == null)" OnClick="QueueJunkAsync" FullWidth="true" Class="mb-2">
                    Mark as Junk
                </MudButton>

                <MudDivider Class="my-2" />
                <MudText Typo="Typo.subtitle2" Class="mb-1">Route To Mailbox</MudText>

                @if (outgoingMailboxes.Count == 0)
                {
                    <MudText Typo="Typo.caption">No outgoing mailboxes configured.</MudText>
                }
                else
                {
                    @foreach (var mailbox in outgoingMailboxes)
                    {
                        <MudButton Variant="Variant.Outlined" Disabled="@(selectedHeader == null)" OnClick="@(() => QueueRouteToMailboxAsync(mailbox))" FullWidth="true" Class="mb-1">
                            @mailbox.DisplayName
                        </MudButton>
                    }
                }

                <MudDivider Class="my-2" />
                <MudText Typo="Typo.subtitle2" Class="mb-1">Outbox Queue</MudText>

                @if (pendingRoutes.Count == 0)
                {
                    <MudText Typo="Typo.caption">No pending routes.</MudText>
                }
                else
                {
                    @foreach (var pending in pendingRoutes)
                    {
                        <MudPaper Class="pa-2 mb-2" Outlined="true">
                            <MudText Typo="Typo.caption">@pending.Header.Subject</MudText>
                            <MudText Typo="Typo.caption">
                                @(pending.ActionType == PendingActionType.Junk ? "Junk" : $"Route: {pending.DestinationName}")
                            </MudText>
                            <MudText Typo="Typo.caption">Undo: @pending.RemainingSeconds s</MudText>
                            <MudStack Row="true" Spacing="1" Class="mt-1">
                                <MudButton Variant="Variant.Text" Color="Color.Error" Disabled="@pending.IsExecuting" OnClick="@(() => CancelPending(pending.Id))">Cancel</MudButton>
                                <MudButton Variant="Variant.Text" Color="Color.Primary" Disabled="@pending.IsExecuting" OnClick="@(() => ExecuteNowAsync(pending.Id))">Execute</MudButton>
                            </MudStack>
                        </MudPaper>
                    }
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    [Inject]
    public MessageApiClient MessageApiClient { get; set; } = default!;

    [Inject]
    public MailboxConfigApiClient MailboxConfigApiClient { get; set; } = default!;

    private readonly List<MessageHeader> headers = [];
    private readonly List<MailboxConfigDto> outgoingMailboxes = [];
    private readonly List<PendingRoute> pendingRoutes = [];
    private readonly CancellationTokenSource timerCts = new();

    private MessageHeader? selectedHeader;
    private String? rawMessage;

    private Boolean isLoading;
    private Boolean isLoadingMessage;

    private String? statusMessage;
    private Severity statusSeverity = Severity.Info;
    private const Int32 UndoWindowSeconds = 15;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _ = Task.Run(() => RunPendingQueueAsync(timerCts.Token));
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        statusMessage = null;

        var loadedHeaders = await MessageApiClient.GetHeadersAsync();
        var loadedOutgoing = await MailboxConfigApiClient.GetMailboxesByTypeAsync("Outgoing") ?? [];

        headers.Clear();
        headers.AddRange(loadedHeaders);

        outgoingMailboxes.Clear();
        outgoingMailboxes.AddRange(loadedOutgoing.Where(x => x.IsActive));

        if (selectedHeader != null)
        {
            var stillExists = headers.FirstOrDefault(x => x.Id == selectedHeader.Id);
            if (stillExists == null)
            {
                selectedHeader = null;
                rawMessage = null;
            }
            else
            {
                selectedHeader = stillExists;
            }
        }

        isLoading = false;
    }

    private async Task SelectMessageAsync(MessageHeader header)
    {
        selectedHeader = header;
        isLoadingMessage = true;
        rawMessage = await MessageApiClient.GetRawMessageAsync(header.Id);
        isLoadingMessage = false;
    }

    private Task QueueJunkAsync()
    {
        if (selectedHeader == null)
        {
            return Task.CompletedTask;
        }

        QueuePending(selectedHeader, PendingActionType.Junk, null);
        return Task.CompletedTask;
    }

    private Task QueueRouteToMailboxAsync(MailboxConfigDto destination)
    {
        if (selectedHeader == null)
        {
            return Task.CompletedTask;
        }

        QueuePending(selectedHeader, PendingActionType.Mailbox, destination);
        return Task.CompletedTask;
    }

    private void QueuePending(MessageHeader header, PendingActionType actionType, MailboxConfigDto? destination)
    {
        var pending = new PendingRoute(
            Guid.NewGuid(),
            header,
            actionType,
            destination?.DisplayName,
            destination == null ? null : new MailboxId(ToGuidFromInt64(destination.Id)),
            DateTimeOffset.UtcNow.AddSeconds(UndoWindowSeconds));

        pendingRoutes.Insert(0, pending);

        headers.RemoveAll(x => x.Id == header.Id);

        if (selectedHeader?.Id == header.Id)
        {
            selectedHeader = headers.FirstOrDefault();
            rawMessage = null;
        }

        statusSeverity = Severity.Info;
        statusMessage = actionType == PendingActionType.Junk
            ? "Message queued for junk. Undo timer started."
            : $"Message queued for routing to {destination?.DisplayName}. Undo timer started.";
    }

    private void CancelPending(Guid pendingId)
    {
        var pending = pendingRoutes.FirstOrDefault(x => x.Id == pendingId);
        if (pending == null || pending.IsExecuting)
        {
            return;
        }

        pendingRoutes.Remove(pending);
        headers.Add(pending.Header);
        headers.Sort((a, b) => b.Date.CompareTo(a.Date));

        statusSeverity = Severity.Info;
        statusMessage = "Queued route canceled and message returned to inbox.";
    }

    private async Task ExecuteNowAsync(Guid pendingId)
    {
        var pending = pendingRoutes.FirstOrDefault(x => x.Id == pendingId);
        if (pending == null)
        {
            return;
        }

        await ExecutePendingAsync(pending);
        await InvokeAsync(StateHasChanged);
    }

    private async Task RunPendingQueueAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        while (await timer.WaitForNextTickAsync(cancellationToken))
        {
            await InvokeAsync(async () =>
            {
                var due = pendingRoutes
                    .Where(x => !x.IsExecuting && x.ExecuteAtUtc <= DateTimeOffset.UtcNow)
                    .ToList();

                foreach (var pending in due)
                {
                    await ExecutePendingAsync(pending);
                }

                StateHasChanged();
            });
        }
    }

    private async Task ExecutePendingAsync(PendingRoute pending)
    {
        if (pending.IsExecuting)
        {
            return;
        }

        pending.IsExecuting = true;
        Boolean success;

        if (pending.ActionType == PendingActionType.Junk)
        {
            success = await MessageApiClient.RouteToJunkAsync(pending.Header.Id);
        }
        else
        {
            if (pending.DestinationMailboxId == null)
            {
                success = false;
            }
            else
            {
                success = await MessageApiClient.RouteToMailboxAsync(pending.Header.Id, pending.DestinationMailboxId.Value);
            }
        }

        if (success)
        {
            statusSeverity = Severity.Success;
            statusMessage = pending.ActionType == PendingActionType.Junk
                ? "Message moved to junk."
                : $"Message routed to {pending.DestinationName}.";

            pendingRoutes.Remove(pending);
        }
        else
        {
            statusSeverity = Severity.Error;
            statusMessage = pending.ActionType == PendingActionType.Junk
                ? "Failed to move message to junk. Message returned to inbox."
                : $"Failed to route message to {pending.DestinationName}. Message returned to inbox.";

            pendingRoutes.Remove(pending);
            headers.Add(pending.Header);
            headers.Sort((a, b) => b.Date.CompareTo(a.Date));
        }
    }

    private static String FormatFrom(FullEmail from)
    {
        var name = String.Join(' ', new[] { from.Name.FirstName, from.Name.LastName }.Where(x => !String.IsNullOrWhiteSpace(x)));
        return String.IsNullOrWhiteSpace(name)
            ? from.Email.Value
            : $"{name} <{from.Email.Value}>";
    }

    private static Guid ToGuidFromInt64(Int64 value)
    {
        Span<byte> bytes = stackalloc byte[16];
        BitConverter.TryWriteBytes(bytes, value);
        return new Guid(bytes);
    }

    public void Dispose()
    {
        timerCts.Cancel();
        timerCts.Dispose();
    }

    private enum PendingActionType
    {
        Junk,
        Mailbox,
    }

    private sealed class PendingRoute
    {
        public PendingRoute(
            Guid id,
            MessageHeader header,
            PendingActionType actionType,
            String? destinationName,
            MailboxId? destinationMailboxId,
            DateTimeOffset executeAtUtc)
        {
            Id = id;
            Header = header;
            ActionType = actionType;
            DestinationName = destinationName;
            DestinationMailboxId = destinationMailboxId;
            ExecuteAtUtc = executeAtUtc;
        }

        public Guid Id { get; }
        public MessageHeader Header { get; }
        public PendingActionType ActionType { get; }
        public String? DestinationName { get; }
        public MailboxId? DestinationMailboxId { get; }
        public DateTimeOffset ExecuteAtUtc { get; }
        public Boolean IsExecuting { get; set; }

        public Int32 RemainingSeconds
        {
            get
            {
                var seconds = (Int32)Math.Ceiling((ExecuteAtUtc - DateTimeOffset.UtcNow).TotalSeconds);
                return seconds < 0 ? 0 : seconds;
            }
        }
    }
}
