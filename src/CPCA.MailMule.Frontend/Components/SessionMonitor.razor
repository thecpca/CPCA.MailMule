@using System.Reflection
@using CPCA.MailMule.Frontend.Services
@inject ISessionApiClient SessionApiClient
@implements IDisposable

@ChildContent

@if (_isBlocked)
{
    <div style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.85); z-index: 9999; display: flex; align-items: center; justify-content: center;">
        <MudPaper Elevation="4" Style="max-width: 500px; padding: 2rem; text-align: center;">
            <MudIcon Icon="@Icons.Material.Filled.Block" Size="Size.Large" Color="Color.Warning" Style="margin-bottom: 1rem;" />
            <MudText Typo="Typo.h5" Color="Color.Warning" GutterBottom="true">
                Session Denied
            </MudText>
            <MudText Typo="Typo.body1" GutterBottom="true">
                Another user is currently the active operator for @_kingdom.
            </MudText>
            <MudDivider Style="margin: 1rem 0;" />
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                Current operator: <strong>@_currentKingName</strong>
            </MudText>
            @if (_timeUntilTimeout.HasValue)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top: 0.5rem;">
                    Will become available in @(_timeUntilTimeout.Value.TotalMinutes.ToString("F0")) minutes
                </MudText>
            }
            <MudDivider Style="margin: 1rem 0;" />
            <MudText Typo="Typo.caption" Color="Color.Default">
                Please contact the current operator or wait for their session to expire.
            </MudText>
            <div style="margin-top: 1.5rem;">
                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="async () => await CheckStatus()">
                    Refresh Status
                </MudButton>
            </div>
        </MudPaper>
    </div>
}

@code {
    private Boolean _isBlocked;
    private String? _currentKingName;
    private TimeSpan? _timeUntilTimeout;
    private CancellationTokenSource? _cts;
    private Timer? _heartbeatTimer;
    private Timer? _refreshTimer;
    private Kingdom? _kingdom;

    /// <summary>
    /// The child content to render. When used as a layout wrapper, this is the page body.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// The page component type resolved by the router. The component reads the
    /// <see cref="KingOfTheHillAttribute"/> from this type to determine kingdom membership.
    /// </summary>
    [Parameter]
    public Type? PageType { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        var newKingdom = ResolveKingdom();

        if (newKingdom == _kingdom)
        {
            return;
        }

        await TearDownSessionAsync();

        _kingdom = newKingdom;

        if (_kingdom.HasValue)
        {
            _cts = new CancellationTokenSource();
            await ClaimKingshipAsync(_kingdom.Value, _cts.Token);
            StartHeartbeat(_kingdom.Value);
            StartRefreshCheck();
        }
        else
        {
            _isBlocked = false;
        }
    }

    private Kingdom? ResolveKingdom()
    {
        if (PageType is null)
        {
            return null;
        }

        var attribute = PageType.GetCustomAttribute<KingOfTheHillAttribute>();
        return attribute?.Kingdom;
    }

    private async Task ClaimKingshipAsync(Kingdom kingdom, CancellationToken cancellationToken)
    {
        var result = await SessionApiClient.ClaimAsync(kingdom, cancellationToken);

        if (result is null)
        {
            return;
        }

        if (!result.Success)
        {
            _isBlocked = true;
            _currentKingName = result.CurrentKingUserName ?? "Unknown";

            var status = await SessionApiClient.GetStatusAsync(kingdom, cancellationToken);
            if (status is not null)
            {
                UpdateTimeUntilTimeout(status);
            }
        }
        else
        {
            _isBlocked = false;
            _currentKingName = null;
            _timeUntilTimeout = null;
        }

        StateHasChanged();
    }

    private async Task CheckStatus()
    {
        if (_cts?.IsCancellationRequested == true || !_kingdom.HasValue) return;
        var status = await SessionApiClient.GetStatusAsync(_kingdom.Value, _cts?.Token ?? CancellationToken.None);

        if (status is null) return;

        if (!status.IsCurrentUserKing && status.CurrentKingUserId is not null)
        {
            _isBlocked = true;
            _currentKingName = status.CurrentKingUserName ?? "Unknown";
            UpdateTimeUntilTimeout(status);
            StateHasChanged();
        }
        else
        {
            _isBlocked = false;
            _currentKingName = null;
            _timeUntilTimeout = null;
            StateHasChanged();
        }
    }

    private void UpdateTimeUntilTimeout(SessionStatusDto status)
    {
        var timeout = TimeSpan.FromMinutes(status.InactivityTimeoutMinutes);
        var elapsed = DateTimeOffset.UtcNow - status.LastActivityUtc;
        var remaining = timeout - elapsed;

        _timeUntilTimeout = remaining > TimeSpan.Zero ? remaining : null;
    }

    private void StartHeartbeat(Kingdom kingdom)
    {
        _heartbeatTimer = new Timer(
            async _ =>
            {
                if (_cts?.IsCancellationRequested == true || _isBlocked) return;
                await SessionApiClient.HeartbeatAsync(kingdom, _cts?.Token ?? CancellationToken.None);
            },
            null,
            TimeSpan.FromSeconds(30),
            TimeSpan.FromSeconds(30));
    }

    private void StartRefreshCheck()
    {
        _refreshTimer = new Timer(
            async _ => await CheckStatus(),
            null,
            TimeSpan.FromMinutes(1),
            TimeSpan.FromMinutes(1));
    }

    private async Task TearDownSessionAsync()
    {
        _cts?.Cancel();
        _heartbeatTimer?.Dispose();
        _heartbeatTimer = null;
        _refreshTimer?.Dispose();
        _refreshTimer = null;

        if (_kingdom.HasValue)
        {
            await SessionApiClient.ReleaseAsync(_kingdom.Value);
        }

        _cts?.Dispose();
        _cts = null;
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _heartbeatTimer?.Dispose();
        _refreshTimer?.Dispose();

        if (_kingdom.HasValue)
        {
            _ = SessionApiClient.ReleaseAsync(_kingdom.Value);
        }
    }
}
